# ===========================
# NoteFlow - Docker Environment
# ===========================
# Copy this file to .env when using Docker Compose

# ===========================
# Application
# ===========================
APP_NAME=NoteFlow
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ===========================
# Database (Docker MySQL)
# ===========================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=noteflow
DB_USERNAME=noteflow
DB_PASSWORD=secret

# ===========================
# Server
# ===========================
APP_PORT=80

# ===========================
# Sanctum
# ===========================
SANCTUM_STATEFUL_DOMAINS=localhost

# ===========================
# Mail
# ===========================
MAIL_MAILER=log

# ===========================
# Session
# ===========================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_SAME_SITE=lax

# ===========================
# Cache & Queue
# ===========================
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
