# ===========================
# NoteFlow - Docker Environment
# ===========================
# Copy this file to .env when using Docker Compose:
#   cp .env.docker.example .env
# Then run:
#   docker compose up -d
#   docker compose exec php-fpm php artisan key:generate
#   docker compose exec php-fpm php artisan migrate:fresh --seed

# ===========================
# Application
# ===========================
APP_NAME=NoteFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost

# ===========================
# Database (Docker MySQL)
# ===========================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=noteflow
DB_USERNAME=noteflow
DB_PASSWORD=secret

# ===========================
# Server
# ===========================
APP_PORT=80

# ===========================
# Sanctum
# ===========================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173

# ===========================
# Mail
# ===========================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@noteflow.test"
MAIL_FROM_NAME="${APP_NAME}"
# To use Mailtrap or another SMTP server:
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ===========================
# Session
# ===========================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_SAME_SITE=lax

# ===========================
# Cache & Queue
# ===========================
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ===========================
# Filesystem (avatars, attachments)
# ===========================
FILESYSTEM_DISK=public

# ===========================
# Broadcasting (Laravel Reverb -> rubric #24 real-time collaboration)
# ===========================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=noteflow
REVERB_APP_KEY=noteflow-key
REVERB_APP_SECRET=noteflow-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_HOST_PORT=8080

# These are read by Vite at build time so the SPA knows where to reach Reverb.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
