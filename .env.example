# ===========================
# NoteFlow - Local Development Environment
# ===========================
# Copy this file to .env when running without Docker.
# For Docker Compose, use .env.docker.example instead.

# ===========================
# Application
# ===========================
APP_NAME=NoteFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_FRONTEND_URL=http://localhost:5173

# ===========================
# Database (XAMPP MySQL)
# ===========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=noteflow
DB_USERNAME=root
DB_PASSWORD=

# ===========================
# Frontend / API
# ===========================
# Vite dev server proxies /api to http://localhost:8000 by default.
# Set VITE_API_URL only if the API is hosted elsewhere.
# VITE_API_URL=http://127.0.0.1:8000/api

# ===========================
# Sanctum
# ===========================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,127.0.0.1:8000

# ===========================
# File Upload
# ===========================
FILESYSTEM_DISK=public
MAX_UPLOAD_SIZE=10240

# ===========================
# Mail (for email verification & password reset)
# ===========================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@noteflow.app"
MAIL_FROM_NAME="NoteFlow"

# Gmail SMTP example for local email verification/password reset.
# Keep real credentials only in .env/backend/.env; never commit them.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-google-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="your-email@gmail.com"

# ===========================
# Session (for Sanctum cookie auth)
# ===========================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ===========================
# Cache
# ===========================
CACHE_STORE=file

# ===========================
# Queue
# ===========================
QUEUE_CONNECTION=sync

# ===========================
# Broadcasting / Reverb
# ===========================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=noteflow
REVERB_APP_KEY=noteflow_key
REVERB_APP_SECRET=noteflow_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Read by Vite at build/dev time so the SPA can connect to Reverb.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# ===========================
# Docker (when using docker-compose.yml)
# ===========================
# DB_HOST=mysql
# DB_DATABASE=noteflow
# DB_USERNAME=noteflow
# DB_PASSWORD=secret
