# ===========================
# NoteFlow - Environment Variables
# ===========================
# Copy this file to .env and fill in your values

# ===========================
# Application
# ===========================
APP_NAME=NoteFlow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:3000

# ===========================
# Database (XAMPP MySQL)
# ===========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=noteflow
DB_USERNAME=root
DB_PASSWORD=

# ===========================
# Backend Server
# ===========================
BACKEND_URL=http://127.0.0.1:8000

# ===========================
# Sanctum
# ===========================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ===========================
# File Upload
# ===========================
FILESYSTEM_DISK=local
MAX_UPLOAD_SIZE=10240

# ===========================
# Mail (for email verification & password reset)
# ===========================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@noteflow.app"
MAIL_FROM_NAME="NoteFlow"

# ===========================
# Session (for Sanctum cookie auth)
# ===========================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_SAME_SITE=lax

# ===========================
# Cache
# ===========================
CACHE_DRIVER=file

# ===========================
# Queue
# ===========================
QUEUE_CONNECTION=sync

# ===========================
# Docker (when using docker-compose.yml)
# ===========================
# DB_HOST=mysql
# DB_DATABASE=noteflow
# DB_USERNAME=noteflow
# DB_PASSWORD=secret
