# ─────────────────────────────────────────
# NoteFlow — Root .gitignore
# Covers both backend/ and frontend/ trees
# ─────────────────────────────────────────

# ── Dependencies ──────────────────────────
vendor/
node_modules/

# ── Environment ───────────────────────────
.env
.env.local
.env.*.local
.env.docker
!.env.example
!.env.docker.example

# ── IDE & Editor ──────────────────────────
.vscode/
.idea/
.fleet/
.nova/
.zed/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── OS ────────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── Logs ──────────────────────────────────
*.log
storage/logs/

# ── Backend: Laravel runtime ──────────────
storage/framework/cache/data/*
!storage/framework/cache/data/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/testing/*
!storage/framework/testing/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
storage/app/public/*
!storage/app/public/.gitkeep
storage/app/private/*
!storage/app/private/.gitkeep
storage/pail/
bootstrap/cache/*.php
public/storage
public/hot

# ── Backend: Database ─────────────────────
database/*.sqlite
database/*.sqlite-journal

# ── Frontend: Build output ────────────────
frontend/dist/
frontend/.vite/

# ── Docker ────────────────────────────────
docker-compose.override.yml

# ── Security ──────────────────────────────
*.pem
*.key
*.crt
auth.json
composer-auth.json