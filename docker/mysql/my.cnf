# ─── MySQL InnoDB Tuning for NoteFlow ─────────────────────────────────────
# These settings assume a Docker container with 512MB-1GB RAM allocated.

[mysqld]
# InnoDB buffer pool — should be ~50-70% of available MySQL memory.
innodb_buffer_pool_size = 256M

# Log file size — larger = fewer checkpoint flushes, better write throughput.
innodb_log_file_size = 64M

# Flush once per second instead of on every commit — big write throughput gain
# at the cost of up to 1 second of data loss on crash (acceptable for notes).
innodb_flush_log_at_trx_commit = 2

# Use O_DIRECT to bypass OS page cache (InnoDB has its own buffer pool).
innodb_flush_method = O_DIRECT

# Sort buffer for ORDER BY / GROUP BY operations.
sort_buffer_size = 4M

# Number of I/O threads for read/write operations.
innodb_read_io_threads = 4
innodb_write_io_threads = 4

# Connection limits
max_connections = 100
wait_timeout = 300

# FULLTEXT search (used by Note::scopeSearch)
innodb_ft_min_token_size = 2
